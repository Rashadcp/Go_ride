NODE_ENV=production
PORT=5001

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Frontend origins
FRONTEND_URL=https://your-frontend-domain.com
ALLOWED_ORIGINS=https://your-frontend-domain.com,http://your-ec2-public-ip

# Auth
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.your-domain.com/api/auth/google/callback

# Redis
REDIS_URL=redis://redis:6379

# AWS / S3
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=goride-storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Messaging / mail
EMAIL_USER=
EMAIL_PASS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
